# Shared
APP_NAME=Client Clearing Lead Gen Engine
ENVIRONMENT=development

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8001
BETTER_AUTH_SECRET=change-me-in-dev
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/deshorn

# Backend
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_SESSION_COOKIE_NAME=better-auth.session_token
DATA_SOURCE_MODE=live
LLM_PROVIDER=gemini
PDF_CACHE_DIR=.tmp/pdf-cache
CLEARING_EXTRACTION_MIN_CONFIDENCE=0.70
SEC_REQUEST_TIMEOUT_SECONDS=30
SEC_REQUEST_MAX_RETRIES=3
SEC_SUBMISSIONS_BASE_URL=https://data.sec.gov/submissions
SEC_ARCHIVES_BASE_URL=https://www.sec.gov/Archives/edgar/data
FOCUS_REPORTS_CSV_PATH=
CONTACT_ENRICHMENT_PROVIDER=disabled
APOLLO_API_KEY=
ZOOMINFO_API_KEY=
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_PDF_MODEL=gemini-2.5-pro
GEMINI_REQUEST_TIMEOUT_SECONDS=120
GEMINI_REQUEST_MAX_RETRIES=2
GEMINI_INLINE_PDF_MAX_SIZE_MB=45
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_PDF_MODEL=gpt-4o
OPENAI_REQUEST_TIMEOUT_SECONDS=120
OPENAI_REQUEST_MAX_RETRIES=2
OPENAI_MAX_PDF_SIZE_MB=45
SEC_USER_AGENT=Alchemy Dev compliance@alchemy.dev
EDGAR_RATE_LIMIT_PER_SECOND=10
FINRA_RATE_LIMIT_PER_SECOND=2

# Email extractor — provider API keys & SMTP-verify knobs
HUNTER_API_KEY=
HUNTER_LIMIT=10
THEHARVESTER_SOURCES=crtsh,rapiddns,otx,duckduckgo
THEHARVESTER_TIMEOUT_SECONDS=90
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=
SNOV_LIMIT=100
SMTP_VERIFY_TIMEOUT_SECONDS=15
SMTP_VERIFY_MAX_BATCH=25
SMTP_VERIFY_CONCURRENCY=1
SMTP_VERIFY_FROM_ADDRESS=verify@email-extractor.local
SMTP_VERIFY_HELO_HOST=email-extractor.local

# Database / Infra
POSTGRES_DB=deshorn
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
REDIS_URL=redis://redis:6379/0
