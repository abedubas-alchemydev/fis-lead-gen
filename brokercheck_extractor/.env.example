# -------------------------------------------------------------------
# Neon Postgres connection (asyncpg driver)
# From the Neon dashboard: Connection Details → "Connection string"
# Make sure you use the POOLED endpoint for batch workloads.
# -------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<ep-xxx>.<region>.aws.neon.tech/<db>?ssl=require

# SEC EDGAR requires a descriptive User-Agent with a contact email.
HTTP_USER_AGENT=BrokerCheckExtractor/1.0 (contact: you@example.com)

# -------------------------------------------------------------------
# Gemini — required for the hybrid pipeline (run-hybrid)
# Get a key at https://aistudio.google.com/apikey
# -------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_LITE=gemini-2.5-flash-lite

# Concurrency / politeness knobs
MAX_CONCURRENCY=5
REQ_TIMEOUT=30
RETRIES=4

# Parsing
ENABLE_OCR=true
RAW_PDF_DIR=./_raw_pdfs
