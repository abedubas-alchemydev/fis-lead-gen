# Frontend env contract for fis-lead-gen (Next.js 14 + BetterAuth)
# Copy to .env.local and fill in real values. Never commit .env.local.

# Public app URL (used by BetterAuth baseURL and trusted origins)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# BetterAuth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-in-dev

# Shared Postgres (Neon in prod; local pg in dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fis_lead_gen

# Backend BFF proxy target
INTERNAL_API_URL=http://127.0.0.1:8001

# SMTP (Google Workspace relay)
SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@alchemydev.io
SMTP_PASSWORD=            # 16-char Google App Password — DO NOT COMMIT
EMAIL_FROM=noreply@alchemydev.io
